# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environment
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Database
data/analytics.db

# ML artifacts (regeneratable from scripts)
data/models/
data/embeddings/
data/results/

# Raw data (sensitive, combined.json is sufficient)
# Ignore everything inside the raw data directory
data/raw/

# Ignore all contents inside the transcript subfolders
data/transcripts/error/*
data/transcripts/incoming/*
data/transcripts/processed/*

# Always track .gitkeep files so empty folders persist in Git
!**/ .gitkeep

# Docs
docs/

# Environment variables
.env
.env.local
.env.*

# Logs
*.log
server.log

# Ruff cache
.ruff_cache/
